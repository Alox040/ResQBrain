{
  "name": "@resqbrain/domain",
  "private": true,
  "version": "0.0.0",
  "main": "./src/index.ts",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./shared": "./src/shared/index.ts"
  },
  "types": "./src/index.ts",
  "scripts": {
    "compile:content": "tsc -p tsconfig.content.json",
    "compile:governance": "tsc -p tsconfig.governance.json",
    "compile:versioning": "tsc -p tsconfig.versioning.json",
    "compile:survey": "tsc -p tsconfig.survey.json",
    "compile:audit": "tsc -p tsconfig.audit.json",
    "compile:lifecycle": "tsc -p tsconfig.lifecycle.json",
    "compile:release": "tsc -p tsconfig.release.json",
    "compile:approval": "tsc -p tsconfig.json",
    "test:audit": "tsx --test src/audit/audit.foundation.test.ts",
    "test:content": "tsx --test src/content/content.entities.test.ts src/content/entities.invariants.test.ts",
    "test:versioning": "tsx --test src/versioning/versioning.entities.test.ts src/versioning/versioning.invariants.test.ts",
    "test:shared:versioning": "tsx --test src/shared/versioning/assertExplicitVersionId.test.ts",
    "test:survey": "tsx --test src/survey/survey.entities.test.ts",
    "test:lifecycle": "tsx --test src/lifecycle/lifecycle.engine.test.ts src/lifecycle/lifecycle.transitions.test.ts src/lifecycle/lifecycle.invariants.test.ts",
    "test:approval": "tsx --test src/governance/approval/approval.engine.test.ts",
    "test:governance:permission": "tsx --test src/governance/services/permission-engine.test.ts",
    "test:release": "tsx --test src/legacy/release/release.engine.test.ts"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
