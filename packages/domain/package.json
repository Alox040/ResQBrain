{
  "name": "@resqbrain/domain",
  "private": true,
  "version": "0.0.0",
  "main": "./src/index.ts",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./shared": "./src/shared/index.ts"
  },
  "types": "./src/index.ts",
  "scripts": {
    "compile:content": "tsc -p tsconfig.content.json",
    "compile:governance": "tsc -p tsconfig.governance.json",
    "compile:versioning": "tsc -p tsconfig.versioning.json",
    "compile:survey": "tsc -p tsconfig.survey.json",
    "test:content": "tsx --test src/content/content.entities.test.ts src/content/entities.invariants.test.ts",
    "test:versioning": "tsx --test src/versioning/versioning.entities.test.ts src/versioning/versioning.invariants.test.ts",
    "test:survey": "tsx --test src/survey/survey.entities.test.ts"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
