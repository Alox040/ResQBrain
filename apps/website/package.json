{
  "name": "@resqbrain/website",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.8.1",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "check:umlauts": "node scripts/check-german-umlauts.js",
    "validate:routing": "tsx ../../scripts/validate-routing.ts",
